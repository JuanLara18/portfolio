# Copy this file to .env.local (git-ignored) and fill in the values.
# The sync pipeline and build-blog-data.js read these via python-dotenv
# (Python) and dotenv (Node). Both loaders are optional — if the file is
# missing, local development falls back to serving audio from
# public/blog/audio/ directly.

# ---- Cloudflare R2 (audio hosting) ---------------------------------------
# Only needed locally for uploading generated MP3s. The deployed site only
# needs the public AUDIO_BASE_URL_* values below.

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# ---- Public audio base URLs ----------------------------------------------
# Absolute URLs that the built site uses to load narrated audio. If unset,
# audio loads from the local public/blog/audio{,-es}/ paths (useful for dev
# before you've set up the bucket).
#
# Example for an R2 public bucket:
#   AUDIO_BASE_URL_EN=https://pub-xxxxxxxxxxxxxxxx.r2.dev/audio
#   AUDIO_BASE_URL_ES=https://pub-xxxxxxxxxxxxxxxx.r2.dev/audio-es

AUDIO_BASE_URL_EN=
AUDIO_BASE_URL_ES=
